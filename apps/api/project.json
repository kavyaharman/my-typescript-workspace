{
  "name": "api",
  "projectType": "application",
  "sourceRoot": "apps/api/src",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "cache": true,
      "outputs": ["{projectRoot}/target/release"],
      "options": {
        "cwd": "apps/api",
        "command": "cargo build --release"
      },
      "configurations": {},
      "metadata": {
        "technologies": ["rust", "actix-web"],
        "description": "Builds the Rust API for production"
      }
    },
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/api",
        "command": "cargo run"
      },
      "configurations": {},
      "metadata": {
        "technologies": ["rust", "actix-web"],
        "description": "Runs the Rust API in development mode"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "cache": true,
      "options": {
        "cwd": "apps/api",
        "command": "cargo test"
      },
      "configurations": {},
      "metadata": {
        "technologies": ["rust"],
        "description": "Runs tests for the Rust API"
      }
    }
  },
  "tags": []
}
